# Backend API (Railway / Render / local `npm run api`)
# Copy to `.env` at repo root for local development.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_GROUNDING=true
GEMINI_MODEL=
PERPLEXITY_API_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

PERSIST_SCANS=true

# Comma-separated browser origins allowed in addition to localhost and *.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Railway/Render set PORT automatically; optional override:
# PORT=3001
# HOST=0.0.0.0

# NODE_ENV=production
